rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApprovedUser() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status in ['approved', 'pending'];
    }

    match /users/{userId} {
      // Solo el usuario y admins pueden leer perfiles (datos sensibles)
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
    
    match /tasks/{taskId} {
      // ✅ Solo usuarios autenticados y aprobados leen tareas
      allow read: if request.auth != null && isApprovedUser();
      
      // ✅ Solo usuarios aprobados crean tareas
      allow create: if request.auth != null && isApprovedUser() && 
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.reward > 0 &&
                       request.resource.data.deadline != null;
      
      // ✅ Solo el autor o admin edita
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid || isAdmin()
      ) &&
      // Prevenir cambios en authorId
      (request.resource.data.authorId == resource.data.authorId);
      
      // ✅ Solo el autor o admin elimina
      allow delete: if request.auth != null && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.creatorId == request.auth.uid || 
        resource.data.applicantId == request.auth.uid || 
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.creatorId == request.auth.uid || 
          get(/databases/$(database)/documents/chats/$(chatId)).data.applicantId == request.auth.uid || 
          isAdmin()
        );
      }
    }

    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId != null;
    }
  }
}
