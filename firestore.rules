rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null; // Other users need to read profile data for chats
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
    
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.creatorId == request.auth.uid || resource.data.applicantId == request.auth.uid || isAdmin());
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (get(/databases/$(database)/documents/chats/$(chatId)).data.creatorId == request.auth.uid || get(/databases/$(database)/documents/chats/$(chatId)).data.applicantId == request.auth.uid || isAdmin());
      }
    }

    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
